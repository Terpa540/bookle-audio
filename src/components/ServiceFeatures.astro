---
const features = [
  "Planificación del proyecto",
  "Coordinación de producción",
  "Grabación profesional",
  "Edición y corrección",
  "Masterización",
  "Control de calidad",
  "Preparación para distribución",
  "Entrega final",
];
---

<section class="section-bookle">

  <div class="container-bookle">

    <div class="max-w-3xl mb-16">

      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-[#315F85]">
        Producción integral
      </p>

      <h2 class="text-4xl font-bold">
        Un proceso completo, coordinado de principio a fin.
      </h2>

    </div>

    <div class="grid gap-6 md:grid-cols-2">

      {
        features.map((feature) => (
          <div class="flex items-center gap-4 rounded-xl border border-gray-200 p-6">

            <div class="h-2 w-2 rounded-full bg-[#315F85]"></div>

            <span>{feature}</span>

          </div>
        ))
      }

    </div>

  </div>

</section>