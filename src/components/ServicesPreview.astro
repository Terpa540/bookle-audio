---
const services = [
  {
    title: "Producción",
    description:
      "Planificación y coordinación integral de proyectos sonoros.",
  },
  {
    title: "Grabación",
    description:
      "Sesiones en estudio o remoto con supervisión técnica.",
  },
  {
    title: "Edición",
    description:
      "Limpieza, corrección y masterización profesional.",
  },
  {
    title: "Distribución",
    description:
      "Preparación de archivos para publicación digital.",
  },
];
---

<section class="section-bookle bg-gray-50">

  <div class="container-bookle">

    <h2 class="mb-16 text-4xl font-bold">
      Todo lo necesario para producir un proyecto profesional.
    </h2>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">

      {
        services.map((service) => (
          <a
              href="/servicios"
              class="group block rounded-2xl border border-gray-200 bg-white p-8 transition duration-300 hover:-translate-y-1 hover:shadow-xl"
            >

            <h3 class="mb-4 text-2xl font-semibold transition group-hover:text-[#315F85]">
              {service.title}
            </h3>

            <p class="text-gray-600">
              {service.description}
            </p>

          </a>
        ))
      }

    </div>

  </div>

</section>