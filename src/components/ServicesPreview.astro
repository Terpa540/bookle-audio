---
const services = [
  {
    title: "Producción integral",
    description:
      "Coordinación completa del proyecto desde la planificación inicial hasta la entrega final.",
  },
  {
    title: "Grabación profesional",
    description:
      "Sesiones supervisadas en estudio o remoto adaptadas a cada producción.",
  },
  {
    title: "Postproducción",
    description:
      "Edición, corrección y masterización para garantizar una experiencia de escucha profesional.",
  },
  {
    title: "Preparación para distribución",
    description:
      "Organización y entrega de materiales listos para plataformas digitales y servicios editoriales.",
  },
];
---

<section class="section-bookle bg-gray-50">

  <div class="container-bookle">

    <h2 class="mb-16 text-4xl font-bold">
      Todo lo necesario para convertir una obra en una experiencia de escucha profesional.
    </h2>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">

      {
        services.map((service) => (
          <a
              href="/servicios"
              class="group block rounded-2xl border border-gray-200 bg-white p-8 transition duration-300 hover:-translate-y-1 hover:shadow-xl"
            >

            <h3 class="mb-4 text-2xl font-semibold transition group-hover:bookle-primary">
              {service.title}
            </h3>

            <p class="text-gray-600">
              {service.description}
            </p>

          </a>
        ))
      }

    </div>

  </div>

</section>