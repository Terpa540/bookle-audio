---
import MainLayout from "../layouts/MainLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<MainLayout title="Proyectos | Bookle">

<PageHero
  title="Experiencia aplicada a cada producción"
  description="Una selección de proyectos y áreas de especialización."
/>

<section class="section-bookle">

  <div class="container-bookle">

    <div class="rounded-xl border border-gray-200 p-10">

      <h2 class="mb-4 text-2xl font-bold">
        Próximamente
      </h2>

      <p class="text-gray-600">
        Estamos preparando una selección de proyectos y casos de estudio.
      </p>

    </div>

  </div>

</section>

</MainLayout>