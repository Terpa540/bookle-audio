---
import MainLayout from "../layouts/MainLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<MainLayout
  title="Servicios | Bookle"
>

<PageHero
  title="Producción profesional de contenido sonoro"
  description="Ofrecemos soluciones completas para proyectos editoriales, corporativos y narrativos."
/>

<section class="section-bookle">

  <div class="container-bookle">

    <div class="grid gap-12 lg:grid-cols-2">

      <div>
        <h2 class="mb-4 text-2xl font-bold">
          Producción de audiolibros
        </h2>

        <p class="text-gray-600">
          Desarrollo integral de proyectos editoriales en formato audio.
        </p>
      </div>

      <div>
        <h2 class="mb-4 text-2xl font-bold">
          Grabación profesional
        </h2>

        <p class="text-gray-600">
          Sesiones en estudio y supervisión técnica especializada.
        </p>
      </div>

      <div>
        <h2 class="mb-4 text-2xl font-bold">
          Edición y masterización
        </h2>

        <p class="text-gray-600">
          Limpieza, corrección y preparación final del audio.
        </p>
      </div>

      <div>
        <h2 class="mb-4 text-2xl font-bold">
          Distribución
        </h2>

        <p class="text-gray-600">
          Entrega de archivos listos para plataformas y servicios de escucha.
        </p>
      </div>

    </div>

  </div>

</section>

</MainLayout>