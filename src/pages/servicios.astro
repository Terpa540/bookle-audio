---
import MainLayout from "../layouts/MainLayout.astro";
import PageHero from "../components/PageHero.astro";
import ServiceBlock from "../components/ServiceBlock.astro";
import FinalCTA from "../components/FinalCTA.astro";
import AudienceBlock from "../components/AudienceBlock.astro";
import ServiceFeatures from "../components/ServiceFeatures.astro";
---

<MainLayout title="Servicios | Bookle">

<PageHero
  title="Producción profesional de audiolibros y contenido narrativo"
  description="Acompañamos a autores, editoriales y empresas durante todo el proceso de producción de sus proyectos."
/>

<section class="section-bookle">

  <div class="container-bookle">

    <div class="max-w-4xl">

      <h2 class="mb-8 text-4xl font-bold">
        Nos ocupamos de todo el proceso.
      </h2>

      <p class="text-xl leading-relaxed text-gray-600">
        Desde la planificación inicial hasta la entrega final, Bookle coordina cada fase necesaria para desarrollar audiolibros y contenido narrativo con los estándares de calidad que exige su distribución profesional.
      </p>

    </div>

  </div>

</section>

<section class="section-bookle">

  <div class="container-bookle">

    <ServiceBlock
      title="Producción de audiolibros"
      description="Gestionamos proyectos editoriales de principio a fin, coordinando todos los elementos necesarios para obtener un resultado profesional."
      features={[
        "Planificación de producción",
        "Coordinación técnica",
        "Control de calidad",
        "Supervisión integral del proyecto"
      ]}
    />

    <ServiceBlock
      title="Grabación profesional"
      description="Realizamos sesiones de grabación adaptadas a cada proyecto, tanto en estudio como en remoto."
      features={[
        "Grabación en estudio",
        "Grabación remota",
        "Supervisión técnica",
        "Dirección de sesión"
      ]}
    />

    <ServiceBlock
      title="Edición y masterización"
      description="Transformamos las grabaciones en productos finales preparados para distribución profesional."
      features={[
        "Limpieza de audio",
        "Corrección de errores",
        "Masterización",
        "Control técnico"
      ]}
    />

    <ServiceBlock
      title="Preparación para distribución"
      description="Preparamos los materiales finales para cumplir los requisitos técnicos de plataformas, servicios editoriales y canales de distribución digital."
      features={[
        "Preparación de archivos",
        "Organización por capítulos",
        "Control de formatos",
        "Entrega final"
      ]}
    />

  </div>

</section>

<AudienceBlock />

<ServiceFeatures />

<FinalCTA />

</MainLayout>