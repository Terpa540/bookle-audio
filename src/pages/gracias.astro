---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Gracias | Bookle"
>

<section class="section-bookle">

  <div class="container-bookle text-center">

    <p class="mb-4 text-sm font-semibold uppercase tracking-widest bookle-primary">
      Solicitud enviada
    </p>

    <h1 class="mb-8 text-5xl font-bold">
      Gracias por contactar con Bookle
    </h1>

    <p class="mx-auto mb-10 max-w-2xl text-xl text-gray-600">
      Hemos recibido tu mensaje correctamente.
      Revisaremos tu proyecto y nos pondremos en contacto contigo lo antes posible.
    </p>

    <a
      href="/"
      class="inline-block rounded-lg bookle-bg-primary px-8 py-4 text-white"
    >
      Volver al inicio
    </a>

  </div>

</section>

</MainLayout>