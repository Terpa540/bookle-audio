---
import MainLayout from "../layouts/MainLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<MainLayout
  title="Nosotros | Bookle"
>

<PageHero
  title="Especialistas en contenido sonoro"
  description="Experiencia, precisión y atención al detalle en cada proyecto."
/>

<section class="section-bookle">

  <div class="container-bookle max-w-4xl">

    <p class="text-xl leading-relaxed text-gray-600">
      Bookle nace de años de experiencia en producción y edición de audio profesional.
      Nuestro objetivo es ayudar a autores, editoriales y empresas a transformar sus
      contenidos en experiencias de escucha de alta calidad.
    </p>

  </div>

</section>

</MainLayout>